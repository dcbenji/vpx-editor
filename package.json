{
  "name": "vpx-editor",
  "productName": "VPX Editor",
  "version": "0.8.3",
  "description": "Visual Pinball X Table Editor",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,ts}\" \"*.{js,ts}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts}\" \"*.{js,ts}\"",
    "dev:web": "vite --config vite.web.config.ts",
    "build:web": "vite build --config vite.web.config.ts",
    "preview:web": "vite preview --config vite.web.config.ts"
  },
  "keywords": [],
  "author": {
    "name": "Jason Millard",
    "email": "jsm174@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jsm174/vpx-editor.git"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.3",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-dmg": "^7.10.2",
    "@electron-forge/maker-flatpak": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron-forge/plugin-vite": "^7.10.2",
    "@electron-forge/publisher-github": "^7.10.2",
    "@electron-forge/shared-types": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "@types/node": "^25.0.3",
    "@types/three": "^0.182.0",
    "electron": "39.2.5",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  },
  "dependencies": {
    "@jsm174/vpin-wasm": "^0.1.0",
    "electron-squirrel-startup": "^1.0.1",
    "fs-extra": "^11.3.3",
    "monaco-editor": "^0.55.1",
    "three": "^0.181.2",
    "update-electron-app": "^3.1.2"
  }
}
